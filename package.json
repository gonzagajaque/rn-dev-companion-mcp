{
  "name": "wiretap-mcp",
  "version": "2.0.0",
  "description": "MCP Server — Real-time React Native debugging for Claude Code. Terminal logs, Hermes/CDP runtime, network inspector, Reactotron integration, iOS/Android crash reports.",
  "author": "Jaqueline Gonzaga <jaqueline_gonzaga@hotmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gonzagajaque/wiretap-mcp.git"
  },
  "homepage": "https://github.com/gonzagajaque/wiretap-mcp#readme",
  "bugs": {
    "url": "https://github.com/gonzagajaque/wiretap-mcp/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "wiretap-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "scripts/install.sh",
    "wiretap.config.json",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "install-mcp": "bash scripts/install.sh",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wiretap",
    "mcp",
    "model-context-protocol",
    "react-native",
    "reactotron",
    "hermes",
    "cdp",
    "chrome-devtools-protocol",
    "debug",
    "debugging",
    "claude-code",
    "claude",
    "ai",
    "network-inspector",
    "crash-reports",
    "metro",
    "expo"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/ws": "^8.5.14",
    "typescript": "^5.7.3"
  }
}
